#!/usr/bin/env python3
import os
import shutil
import sys

def check_disk_full(disk, min_gb, max_percent):
    """
    指定されたディスクの空き容量と使用率をチェックする関数
    ※引数名を min_absolute から min_gb にリネームして分かりやすくしました
    """
    du = shutil.disk_usage(disk)
    
    # バイトからギガバイト(GB)に変換
    free_gb = du.free / (2**30)
    # 使用率(%)を計算
    percent_used = 100 * du.used / du.total
    
    # 条件式をパラメータの順序（min_gb -> max_percent）に合わせて並び替え
    if free_gb < min_gb or percent_used > max_percent:
        return True
    return False

def check_root_full():
    """
    ルートディレクトリ「/」のディスク状態をチェックするラッパー関数
    """
    # 最小空き容量: 2GB、最大使用率: 80% でチェックを実行
    return check_disk_full(disk="/", min_gb=2, max_percent=80)

def main():
    # 1. 行いたいチェック関数と、異常時のエラーメッセージをペアにしてリスト化
    # (コードの重複を避けるために、リストで管理して繰り返し処理できるようにリファクタリング)
    checks = [
        (check_root_full, "エラー: ルートパーティションの容量が不足しています。"),
        # 今後、CPU負荷チェック(check_load)などをここに追加するだけで簡単に拡張できます
    ]
    
    # システム全体が正常かどうかのフラグ
    everything_ok = True
    
    # 2. リストをループ処理して、すべてのチェックを実行する
    # (途中で終了せず、すべてのエラーメッセージをまとめて表示できるように改良)
    for check_function, error_message in checks:
        if check_function():
            print(error_message)
            everything_ok = False  # 1つでも異常があればフラグを倒す
            
    # 3. 最終的なステータス判定
    if not everything_ok:
        # 異常があった場合は、終了コード 1 でプログラムを落とす
        sys.exit(1)
        
    print("すべてのシステムチェックが正常に完了しました。")
    sys.exit(0)

if __name__ == "__main__":
    main()



## プログラムの概要（all_checks.py）

このスクリプトは、サーバーやPCのシステム環境が正常に動作しているかを自動的に検査するためのヘルスチェックツールです。
現在は主に**ディスクの空き容量と使用率の監視**を行っています。

### 🛠️ 開発におけるリファクタリングのポイント

このコードは、複数人の開発者が並行して機能追加・コードのクリーンアップ（リファクタリング）を行った成果物です。主に以下の3つの改良が行われています。

#### 1. 可読性の向上とパラメータの整理
* ディスクチェック関数（`check_disk_full`）の引数を、より直感的に分かりやすい `min_gb` という名称に変更しました。
* 条件式の並び順を、引数の順番（`min_gb` -> `max_percent`）に統一し、コードを読む人が迷わないように配慮しています。

#### 2. ラッパー関数による関数の部品化
* 具体的なチェック（ルートディレクトリ `/` を「残り2GB以下 / 使用率80%以上」で調べる）を行うための専用の関数（`check_root_full`）を分離して作成しました。
* これにより、将来的に「特定のデータフォルダだけ別の基準でチェックしたい」となった場合でも、関数を新しく定義するだけで安全に拡張できます。

#### 3. コードの重複排除と「複数エラー」の同時出力
* 最も大きな改良として、行いたいチェックを **`[(関数, メッセージ), (関数, メッセージ)]` というリスト形式で管理** するようにしました。
* これにより、以下のようなメリットがあります。
  * **重複コードの排除:** 新しいチェック項目（CPU負荷やメモリなど）が増えても、`main()` 関数の中に同じような `if` 文を何個も書く必要がなくなり、リストに1行追加するだけで済みます。
  * **エラーのまとめ出力:** 最初の異常が見つかった時点でプログラムをすぐに終了（`sys.exit`）させるのではなく、**最後まで全てのチェックを走りきらせる**ことで、発生している複数のエラーメッセージを画面に一括で表示できるようになりました。
